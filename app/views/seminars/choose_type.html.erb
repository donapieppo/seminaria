<h1 class="mb-2">Inserisci un nuovo seminario</h1>
<p class="lead mb-0">
Scegli il tipo di seminario per
<span class="fw-semibold"><%= current_organization.description %></span>.
</p>

<div class="card border-primary shadow-sm my-3">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
      <div>
        <h2 class="h4 mb-2">Singolo seminario</h2>
        <p class="text-muted mb-0">
        Usa questa opzione se il seminario non appartiene a un ciclo, un convegno o una serie.
        </p>
      </div>
      <div class="d-grid">
        <%= link_to "Inserisci singolo seminario", new_seminar_path, class: "btn btn-primary btn-lg" %>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm h-100 my-3">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
      <div>
        <h2 class="h4 mb-2">Seminario in un ciclo</h2>
        <p class="text-muted mb-0">
        Scegli un ciclo esistente oppure creane uno nuovo prima di inserire il seminario.
        </p>
      </div>
      <div class="d-grid gap-2">
        <%= link_to "Crea nuovo ciclo", new_cycle_path, class: "btn btn-outline-primary" %>
      </div>
    </div>

    <% if @cycles.empty? %>
      <div class="alert alert-warning mb-0">
        Non risultano cicli di seminari da te organizzati presso <strong><%= current_organization.description %></strong>.
      </div>
    <% else %>
      <div class="list-group">
        <% @cycles.each do |cycle| %>
          <%= link_to cycle.to_s.upcase, new_cycle_seminar_path(cycle), class: "list-group-item list-group-item-action" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm h-100 my-3">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
      <div>
        <h2 class="h4 mb-2">Seminario in un convegno</h2>
        <p class="text-muted mb-0">
        Se il seminario fa parte di un convegno, seleziona il convegno corretto dall'elenco.
        </p>
      </div>
      <div class="d-grid gap-2">
        <%= link_to "Crea nuovo convegno", new_conference_path, class: "btn btn-outline-primary" %>
      </div>
    </div>

    <% if @conferences.empty? %>
      <div class="alert alert-warning mb-0">
        Non risultano convegni da te organizzati presso <strong><%= current_organization.description %></strong>.
      </div>
    <% else %>
      <div class="list-group">
        <% @conferences.each do |conference| %>
          <%= link_to conference.to_s.upcase, new_conference_seminar_path(conference), class: "list-group-item list-group-item-action" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm h-100 my-3">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
      <div>
        <h2 class="h4 mb-2">Seminario in una serie</h2>
        <p class="text-muted mb-0">
        Seleziona una serie attiva per inserire il seminario al suo interno.
        </p>
      </div>
      <% if policy(current_organization).manage? %>
        <div class="d-grid gap-2">
          <%= link_to "Nuova serie", new_serial_path, class: "btn btn-outline-primary" %>
          <%= link_to "Tutte le serie", serials_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>

    <% if @serials.empty? %>
      <div class="alert alert-secondary mb-0">
        Non sono presenti serie attive per questa organizzazione.
      </div>
    <% else %>
      <div class="list-group">
        <% @serials.each do |serial| %>
          <%= link_to serial.to_s.upcase, new_serial_seminar_path(serial), class: "list-group-item list-group-item-action" %>
        <% end %>
      </div>
    <% end %>

    <% unless policy(current_organization).manage? %>
      <div class="alert alert-info mt-3 mb-0">
        Per inserire una nuova serie, invia la richiesta all'amministrazione.
      </div>
    <% end %>
  </div>
</div>
